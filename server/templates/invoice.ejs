<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Invoice - <%= doc.invoiceNumber %></title>
    <!-- Use Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #2563eb;         /* Blue */
            --primary-light: #eff6ff;   
            --text-main: #0f172a;       
            --text-muted: #64748b;
            --border-color: #e2e8f0;
            --bg-gray: #f8fafc;
            --success: #10b981;
            --success-bg: #d1fae5;
            --warning: #f59e0b;
            --warning-bg: #fef3c7;
            --danger: #ef4444;
            --danger-bg: #fee2e2;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-main);
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-size: 13px;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 40px;
            background: #ffffff;
        }

        /* --- HEADER SECTION --- */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
            border-bottom: 2px solid var(--primary);
            padding-bottom: 20px;
        }

        .company-details {
            display: flex;
            flex-direction: column;
        }

        .company-logo-area {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }

        .logo-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--primary), #1e40af);
            border-radius: 12px;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 24px;
            font-weight: 700;
            margin-right: 15px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .company-name {
            font-size: 24px;
            font-weight: 700;
            margin: 0;
            color: var(--text-main);
            letter-spacing: -0.5px;
        }

        .company-address {
            color: var(--text-muted);
            line-height: 1.5;
            font-size: 12px;
        }

        .invoice-title-area {
            text-align: right;
        }

        .invoice-title {
            font-size: 36px;
            font-weight: 700;
            color: var(--primary);
            margin: 0 0 10px 0;
            letter-spacing: -1px;
            text-transform: uppercase;
        }

        .meta-grid {
            display: grid;
            grid-template-columns: auto auto;
            gap: 8px 20px;
            text-align: left;
            background: var(--bg-gray);
            padding: 15px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
        }

        .meta-label {
            font-weight: 600;
            color: var(--text-muted);
            font-size: 12px;
        }

        .meta-value {
            font-weight: 600;
            color: var(--text-main);
            text-align: right;
        }

        /* --- BILLING SECTION --- */
        .billing-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-bottom: 40px;
        }

        .billing-card {
            background: white;
        }

        .billing-title {
            font-size: 12px;
            text-transform: uppercase;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 10px;
            letter-spacing: 0.5px;
        }

        .billing-name {
            font-size: 18px;
            font-weight: 700;
            margin: 0 0 5px 0;
            color: var(--text-main);
        }

        .billing-details {
            color: var(--text-muted);
            line-height: 1.6;
        }

        /* --- STATUS BADGE --- */
        .status-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 10px;
        }
        
        .status-Paid { background: var(--success-bg); color: var(--success); }
        .status-Partially { background: var(--warning-bg); color: var(--warning); }
        .status-Unpaid { background: var(--danger-bg); color: var(--danger); }

        /* --- ITEMS TABLE --- */
        .items-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-bottom: 30px;
        }

        .items-table th {
            background: var(--bg-gray);
            color: var(--text-muted);
            font-weight: 600;
            font-size: 12px;
            text-transform: uppercase;
            padding: 12px 15px;
            text-align: left;
            border-top: 1px solid var(--border-color);
            border-bottom: 2px solid var(--border-color);
        }

        .items-table td {
            padding: 15px;
            border-bottom: 1px solid var(--border-color);
            color: var(--text-main);
            page-break-inside: avoid;
        }

        .items-table th:first-child, .items-table td:first-child { border-top-left-radius: 8px; border-bottom-left-radius: 8px; }
        .items-table th:last-child, .items-table td:last-child { border-top-right-radius: 8px; border-bottom-right-radius: 8px; text-align: right; }
        .items-table th:nth-child(3), .items-table td:nth-child(3),
        .items-table th:nth-child(4), .items-table td:nth-child(4) { text-align: right; }

        .item-desc {
            font-weight: 500;
            margin: 0;
            color: var(--text-main);
        }

        /* --- SUMMARY SECTION --- */
        .summary-section {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 50px;
            page-break-inside: avoid;
        }

        .summary-box {
            width: 320px;
            background: var(--bg-gray);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid var(--border-color);
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            color: var(--text-muted);
        }

        .summary-row.total {
            border-top: 2px solid var(--border-color);
            margin-top: 10px;
            padding-top: 15px;
            color: var(--text-main);
            font-size: 18px;
            font-weight: 700;
        }
        
        .summary-row.paid {
            color: var(--success);
            font-weight: 600;
        }
        
        .summary-row.due {
            background: var(--primary-light);
            padding: 12px;
            border-radius: 8px;
            margin-top: 10px;
            color: var(--primary);
            font-weight: 700;
            font-size: 16px;
        }

        .summary-value {
            font-weight: 600;
            color: var(--text-main);
        }
        
        .summary-row.paid .summary-value { color: var(--success); }
        .summary-row.due .summary-value { color: var(--primary); }

        /* --- FOOTER --- */
        .footer {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            page-break-inside: avoid;
            color: var(--text-muted);
            font-size: 12px;
        }

        .terms h4 {
            color: var(--text-main);
            font-size: 14px;
            margin: 0 0 5px 0;
        }
        
        .terms p {
            margin: 0;
            line-height: 1.5;
            max-width: 400px;
        }

        .authorities {
            text-align: right;
        }

        .signature {
            font-family: 'Brush Script MT', cursive, sans-serif;
            font-size: 28px;
            color: var(--primary);
            margin-bottom: 5px;
            opacity: 0.8;
            transform: rotate(-3deg);
        }

        .auth-name {
            font-weight: 600;
            color: var(--text-main);
            margin: 0;
        }

        @media print {
            body { 
                -webkit-print-color-adjust: exact; 
                print-color-adjust: exact;
            }
            .container { padding: 0; max-width: 100%; border: none; box-shadow: none; }
        }
    </style>
</head>
<body>
    <div class="container">
        
        <!-- HEADER -->
        <div class="header">
            <div class="company-details">
                <div class="company-logo-area">
                    <div class="logo-icon">M</div>
                    <h1 class="company-name">MERN Procurement</h1>
                </div>
                <div class="company-address">
                    123 Business Avenue, Tech Park<br>
                    San Francisco, CA 94107<br>
                    contact@mernprocurement.com<br>
                    +1 (555) 123-4567
                </div>
            </div>

            <div class="invoice-title-area">
                <h2 class="invoice-title">Invoice</h2>
                <div class="meta-grid">
                    <div class="meta-label">Invoice #</div>
                    <div class="meta-value"><%= doc.invoiceNumber %></div>
                    
                    <div class="meta-label">Date</div>
                    <div class="meta-value"><%= date %></div>
                    
                    <div class="meta-label">PO Ref</div>
                    <div class="meta-value"><%= doc.poId?.poNumber || 'N/A' %></div>
                </div>
            </div>
        </div>

        <!-- BILLING INFO -->
        <div class="billing-section">
            <div class="billing-card">
                <div class="billing-title">Billed To</div>
                <h3 class="billing-name"><%= doc.vendorId?.vendorName || 'Client Name' %></h3>
                <div class="billing-details">
                    <%= doc.vendorId?.address || '123 Client Street, City' %><br>
                    <%= doc.vendorId?.contactDetails || '555-987-6543' %><br>
                    <%= doc.vendorId?.email || 'client@example.com' %>
                    
                    <% 
                    let statusClass = "status-Unpaid";
                    if(doc.status === 'Paid') statusClass = "status-Paid";
                    if(doc.status === 'Partially Paid') statusClass = "status-Partially";
                    %>
                    <br>
                    <span class="status-badge <%= statusClass %>"><%= doc.status || 'Unpaid' %></span>
                </div>
            </div>
            <div class="billing-card">
                <div class="billing-title">Payment Info</div>
                <div class="billing-details">
                    <strong>Bank Name:</strong> Global Tech Bank<br>
                    <strong>Account No:</strong> 0987-6543-2100<br>
                    <strong>Routing No:</strong> 121000358<br>
                    <strong>SWIFT:</strong> GLTBUS33
                </div>
            </div>
        </div>

        <!-- ITEMS TABLE -->
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width: 5%">#</th>
                    <th style="width: 50%">Item Description</th>
                    <th style="width: 15%">Qty</th>
                    <th style="width: 15%">Unit Price</th>
                    <th style="width: 15%">Total</th>
                </tr>
            </thead>
            <tbody>
                <% (doc.lineItems || doc.items || []).forEach((item, index) => { %>
                <tr>
                    <td style="color: var(--text-muted)"><%= index + 1 %></td>
                    <td>
                        <p class="item-desc"><%= item.itemName || item.description %></p>
                    </td>
                    <td><%= item.quantity || item.qty || 1 %></td>
                    <td>$<%= (item.unitPrice || item.price || 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                    <td>$<%= ((item.quantity || item.qty || 1) * (item.unitPrice || item.price || 0)).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <!-- SUMMARY -->
        <div class="summary-section">
            <div class="summary-box">
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span class="summary-value">$<%= (doc.subtotal || 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
                </div>
                <div class="summary-row">
                    <% 
                    let taxRate = 0;
                    if(doc.items && doc.items[0]) taxRate = doc.items[0].tax;
                    %>
                    <span>Tax (<%= taxRate %>%)</span>
                    <span class="summary-value">$<%= (doc.tax || 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
                </div>
                
                <div class="summary-row total">
                    <span>Grand Total</span>
                    <span>$<%= (doc.grandTotal || 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
                </div>

                <% if(typeof totalPaid !== 'undefined') { %>
                <div class="summary-row paid">
                    <span>Amount Paid</span>
                    <span class="summary-value">-$<%= (totalPaid || 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
                </div>
                <div class="summary-row due">
                    <span>Balance Due</span>
                    <span class="summary-value">$<%= (amountDue || 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
                </div>
                <% } else { %>
                <div class="summary-row due">
                    <span>Amount Due</span>
                    <span class="summary-value">$<%= (doc.grandTotal || 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
                </div>
                <% } %>
            </div>
        </div>

        <!-- FOOTER -->
        <div class="footer">
            <div class="terms">
                <h4>Terms & Conditions</h4>
                <p>Please send payment within 30 days of receiving this invoice. There will be a 10% interest charge per month on late invoices. Thank you for your business!</p>
            </div>
            <div class="authorities">
                <div class="signature"><%= doc.createdBy?.name || 'Authorized Signatory' %></div>
                <p class="auth-name"><%= doc.createdBy?.name || 'Admin' %></p>
                <p style="margin:0; font-size: 11px;">Authorized Signatory</p>
            </div>
        </div>

    </div>
</body>
</html>
